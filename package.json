{
  "name": "mcp-writing-vscode",
  "displayName": "MCP Writing",
  "description": "VS Code companion extension for MCP Writing setup flows",
  "version": "0.0.3",
  "publisher": "hannasdev",
  "icon": "mcp-writing-logo.png",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/hannasdev/mcp-writing-vscode",
  "repository": {
    "type": "git",
    "url": "https://github.com/hannasdev/mcp-writing-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/hannasdev/mcp-writing-vscode/issues"
  },
  "keywords": [
    "mcp",
    "writing",
    "vscode",
    "styleguide",
    "scrivener",
    "creative-writing",
    "authoring",
    "editorial"
  ],
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other",
    "Education",
    "Formatters"
  ],
  "galleryBanner": {
    "color": "#1F2937",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:mcpWriting.setupProseStyleguide",
    "onCommand:mcpWriting.testServerConnection",
    "onCommand:mcpWriting.updateProseStyleguide"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "configuration": {
      "title": "MCP Writing",
      "properties": {
        "mcpWriting.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL for the MCP Writing server (SSE transport)."
        }
      }
    },
    "commands": [
      {
        "command": "mcpWriting.setupProseStyleguide",
        "title": "MCP Writing: Setup Prose Styleguide"
      },
      {
        "command": "mcpWriting.updateProseStyleguide",
        "title": "MCP Writing: Update Prose Styleguide"
      },
      {
        "command": "mcpWriting.testServerConnection",
        "title": "MCP Writing: Test Server Connection"
      }
    ]
  },
  "scripts": {
    "lint": "echo 'Add lint config'",
    "test": "node --test test/*.test.cjs",
    "package": "vsce package",
    "publish:marketplace": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.3.2"
  }
}
